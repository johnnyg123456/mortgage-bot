# Copy to .env for local dev. On Render, add these in Dashboard > Environment.

# Notion
NOTION_TOKEN=
NOTION_LOANS_DB_ID=
NOTION_CONDITIONS_DB_ID=

# Anthropic (3-checker validator)
ANTHROPIC_API_KEY=
VALIDATOR_ENABLED=true

# Gmail — John (primary)
GMAIL_CLIENT_ID_PRIMARY=
GMAIL_CLIENT_SECRET_PRIMARY=
GMAIL_REFRESH_TOKEN_PRIMARY=

# Gmail — Christy
GMAIL_CLIENT_ID_CHRISTY=
GMAIL_CLIENT_SECRET_CHRISTY=
GMAIL_REFRESH_TOKEN_CHRISTY=

JOHN_EMAIL=
CHRISTINA_EMAIL=

# Arive webhook auth (optional)
ZAPIER_STATIC_HEADER_KEY=

# Set true only for testing — skips Notion writes and emails
DRY_RUN=false

# Render: run full Gmail scan in request (recommended)
GMAIL_SCAN_SYNC=true
GMAIL_SCAN_TIMEZONE=America/New_York
# Hidden Gmail label applied after bot handles an email; excluded from future scans
GMAIL_PROCESSED_LABEL=mortgage-bot-processed
# Keep emails unread in Gmail after the bot processes them (default true)
GMAIL_PRESERVE_UNREAD=true
GMAIL_MAX_MESSAGES_PER_INBOX=25
GMAIL_MAX_TOTAL_PER_INBOX_PER_SCAN=50

# Notion property overrides (only if your database uses different column names)
# NOTION_LOAN_NUMBER_PROPERTY=Loan Number
# NOTION_BORROWER_LAST_NAME_PROPERTY=Borrower Last Name
# NOTION_LENDER_PROPERTY=Lender
